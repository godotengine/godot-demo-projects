[node name="DemoScene_SetupInstructions" type="RichTextLabel" parent="DemoScenes" unique_id=660978631]
visible = false
layout_mode = 0
offset_left = 7.0
offset_top = 4.0
offset_right = 820.0
offset_bottom = 556.0
focus_mode = 2
theme_override_fonts/mono_font = SubResource("SystemFont_7mycd")
bbcode_enabled = true
text = "1) Ensure [i]no[/i] Environment resources use SDR-only features:
	- Tonemap Mode: Filmic or ACES
	- Glow Blend Mode: Soft Light
	- Adjustments: Color Correction

2) Configure the [code]rendering/renderer/rendering_method[/code] project setting to [code]mobile[/code] or [code]forward_plus[/code].

3) Configure the [code]rendering/rendering_device/driver[/code] advanced project setting to [code]metal[/code] for iOS and [code]d3d12[/code] for Windows.

4) Configure the [code]display/display_server/driver.linuxbsd[/code] project setting to [code]wayland[/code] and enable the [code]run/platforms/linuxbsd/prefer_wayland[/code] editor setting.

5) Turn on the [code]rendering/viewport/hdr_2d[/code] project setting and enable [code]use_hdr_2d[/code] for all SubViewports and Windows that should support HDR output.

6) Turn on the [code]display/window/hdr/request_hdr_output[/code] project setting and enable [code]hdr_output_requested[/code] for all other Windows that should support HDR output.

7) [Optional] Provide in-game settings for the player by copying [code]in_game_hdr_settings[/code] from this demo to your project.

View the [url=https://docs.godotengine.org/en/latest/tutorials/rendering/hdr_output.html]manual page[/url] to learn more about HDR output."
context_menu_enabled = true
vertical_alignment = 1
selection_enabled = true
drag_and_drop_selection_enabled = false
script = ExtResource("13_w48qg")

